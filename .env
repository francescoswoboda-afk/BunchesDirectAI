# Stripe
STRIPE_SECRET_KEY=

# SMTP – fill in your email provider credentials
# Example for Gmail: host=smtp.gmail.com, port=465, secure=true
# Use an App Password if 2FA is enabled on the account
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=es@bunches-direct.com
SMTP_PASS=your_app_password_here

# Address that receives order emails
ORDER_TO_EMAIL=es@bunches-direct.com
